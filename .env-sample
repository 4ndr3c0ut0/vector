# ===== V.E.C.T.O.R. — modelo de variaveis de ambiente =====
# Copie para .env e ajuste os valores:  cp .env-sample .env
# O docker compose le o .env automaticamente.

# --- Frontend (o jogo) ---
# Porta do host para acessar o jogo: http://localhost:FRONTEND_PORT
FRONTEND_PORT=8080
# URL da API para ranking online. Vazio = jogo 100% offline.
VITE_API_URL=

# --- Backend (sobe apenas com o perfil "full") ---
BACKEND_PORT=8081
BACKEND_ENV=production
CORS_ORIGINS=*

# --- Postgres (sobe apenas com o perfil "full") ---
POSTGRES_DB=vector
POSTGRES_USER=vector
POSTGRES_PASSWORD=troque-esta-senha
POSTGRES_PORT=5432
